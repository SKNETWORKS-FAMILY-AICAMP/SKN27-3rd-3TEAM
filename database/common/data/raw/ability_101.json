{
  "effect_changes": [
    {
      "effect_entries": [
        {
          "effect": "Lutte n'est pas affecté. Coup d’Main et Boul’Armure ne sont pas pris en compte.",
          "language": {
            "name": "fr",
            "url": "https://pokeapi.co/api/v2/language/5/"
          }
        },
        {
          "effect": "Verzweifler wird nicht beeinflusst. Rechte Hand und Einigler werden nicht beachtet.",
          "language": {
            "name": "de",
            "url": "https://pokeapi.co/api/v2/language/6/"
          }
        },
        {
          "effect": "Struggle is unaffected.  Helping Hand and Defense Curl are not taken into account.",
          "language": {
            "name": "en",
            "url": "https://pokeapi.co/api/v2/language/9/"
          }
        }
      ],
      "version_group": {
        "name": "black-white",
        "url": "https://pokeapi.co/api/v2/version-group/11/"
      }
    }
  ],
  "effect_entries": [
    {
      "effect": "Les capacités de ce Pokémon ont 1.5× leur puissance si leur puissance de base est 60 ou moins.\n\nCeci inclut les capacités de puissance variable, telles que Puissance Cachée et Ampleur, quand leur puissance est 60 ou moins.  Le boost de puissance de Coup d’Main est pris en compte pour n’importe quelle capacité, comme le boost de puissance de Boul’Armure pour Roulade.",
      "language": {
        "name": "fr",
        "url": "https://pokeapi.co/api/v2/language/5/"
      },
      "short_effect": "Renforce les capacités à 60 de puissance de base ou moins d'1.5× leur puissance."
    },
    {
      "effect": "Attacken von Pokémon mit dieser Fähigkeit die eine Stärke von 60 oder weniger haben werden um 50% verstärkt.\n\nDas schließt Attacken mit variabler Stärke, wie Kraftreserve oder Intensität, mit ein, wenn ihre Stärke 60 oder weniger ist. Der Stärke Bonus von Rechte Hand wird miteinberechnet, genauso wie der von Einigler für Walzer.",
      "language": {
        "name": "de",
        "url": "https://pokeapi.co/api/v2/language/6/"
      },
      "short_effect": "Versärkt Attacken mit einer Basisstärke von 60 oder weniger um 50%."
    },
    {
      "effect": "This Pokémon's moves have 1.5× their power if their base power is 60 or less.\n\nThis includes moves of variable power, such as Hidden Power and Magnitude, when their power is 60 or less.  Helping Hand's power boost is taken into account for any move, as is Defense Curl's power boost for Rollout.",
      "language": {
        "name": "en",
        "url": "https://pokeapi.co/api/v2/language/9/"
      },
      "short_effect": "Strengthens moves of 60 base power or less to 1.5× their power."
    }
  ],
